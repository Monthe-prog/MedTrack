# =============================================================================
# MedTrack – Environment Variables Example
# Package : com.joechrist.medtrack
# Copy to : .env  (never commit .env to version control)
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
APP_PORT=8080
APP_SECRET=change_me_to_a_64_char_random_secret_string_for_jwt_signing

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=medtrack_db
POSTGRES_USER=medtrack_user
POSTGRES_PASSWORD=S3cur3P@ssw0rd!
POSTGRES_PORT=5432

# ── MinIO (S3-Compatible Storage) ─────────────────────────────────────────────
MINIO_ROOT_USER=medtrack_minio_admin
MINIO_ROOT_PASSWORD=M1n10S3cur3!
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_PROFILES=medtrack-profiles
MINIO_BUCKET_PRESCRIPTIONS=medtrack-prescriptions

# ── Gotenberg (PDF Engine) ────────────────────────────────────────────────────
GOTENBERG_PORT=3000

# ── Firebase (Auth & FCM) ─────────────────────────────────────────────────────
# From Firebase Console → Project Settings → Service Accounts → Generate Key
FIREBASE_PROJECT_ID=medtrack-8b6a1
# Path to the service-account JSON file mounted into the Ktor container,
# OR an inline base64-encoded JSON string (recommended for CI/CD).
FIREBASE_SERVICE_ACCOUNT_KEY=/app/firebase/service-account.json

# ── openFDA ───────────────────────────────────────────────────────────────────
# Free-tier key from: https://open.fda.gov/apis/authentication/
# Leave blank to use the anonymous tier (rate-limited to 1 000 req/day).
OPENFDA_API_KEY=

# ── pgAdmin (dev only) ────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@medtrack.local
PGADMIN_PASSWORD=admin

# ── Android / Mobile (reference, consumed at build time via local.properties) ─
# com.joechrist.medtrack
ANDROID_PACKAGE_NAME=com.joechrist.medtrack
ANDROID_APP_NAME=MedTrack
# Paste the google-services.json Web API key here for CI builds
ANDROID_FIREBASE_WEB_API_KEY=AIzaSyAiLIr8Q_F-UZNsUHPYZP4SRlLpa1XQo34
# Backend base URL visible to the emulator/device
ANDROID_API_BASE_URL=http://10.0.2.2:8080   # emulator → host loopback
# ANDROID_API_BASE_URL=https://api.medtrack.yourdomain.com
