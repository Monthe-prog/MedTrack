# =============================================================================
# MedTrack – .gitignore
# =============================================================================

# ── Secrets (NEVER commit these) ─────────────────────────────────────────────
.env
*.env.local
backend/resources/firebase/service-account.json
android/app/google-services.json
android/local.properties

# ── Gradle ────────────────────────────────────────────────────────────────────
.gradle/
build/
**/build/
*.class
gradle/gradle-daemon-jvm.properties
!gradle/wrapper/gradle-wrapper.jar

# ── Android ───────────────────────────────────────────────────────────────────
android/.idea/
android/captures/
android/local.properties
android/**/*.apk
android/**/*.aab
android/**/*.keystore
*.jks

# ── Ktor / JVM ────────────────────────────────────────────────────────────────
backend/out/
*.jar
!gradle/wrapper/gradle-wrapper.jar

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/
docker-compose.override.yml

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
*.swo
.DS_Store

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Let's Encrypt / Nginx ─────────────────────────────────────────────────────
infra/nginx/certs/
