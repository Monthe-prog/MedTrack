<?xml version="1.0" encoding="utf-8"?>
<!--
    MedTrack – data_extraction_rules.xml (Android 12+)
    Controls what data can be extracted by Android backup/transfer mechanisms.
    All patient health data must be excluded to comply with HIPAA intent.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="medtrack.db"/>
        <exclude domain="database" path="medtrack.db-shm"/>
        <exclude domain="database" path="medtrack.db-wal"/>
        <exclude domain="file" path="datastore/"/>
        <exclude domain="sharedpref" path="."/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="medtrack.db"/>
        <exclude domain="database" path="medtrack.db-shm"/>
        <exclude domain="database" path="medtrack.db-wal"/>
        <exclude domain="file" path="datastore/"/>
        <exclude domain="sharedpref" path="."/>
    </device-transfer>
</data-extraction-rules>
